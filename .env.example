# Cloudflare R2 Configuration
# Save your actual credentials in .env (don't commit to git)
# This is a template - fill in your values

# From Cloudflare Dashboard → R2 → API Tokens
R2_ACCOUNT_ID=your_account_id_here
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
R2_BUCKET_NAME=soyjak-training
R2_ENDPOINT=https://your_account_id.r2.cloudflarestorage.com

# Lambda Labs (optional - only needed for training)
LAMBDA_API_KEY=your_lambda_api_key_here

# HuggingFace (optional - only needed for deployment)
HF_TOKEN=your_huggingface_token_here
HF_MODEL_NAME=soyjak-lora-sdxl
HF_REPO_ID=your_username/soyjak-lora-sdxl
